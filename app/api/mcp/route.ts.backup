import { NextRequest, NextResponse } from 'next/server';
import { getBooks, getBookById, searchBooks } from '@/lib/mdx';

export async function POST(request: NextRequest) {
  try {
    const body = await request.json();
    const { method, params } = body;

    let result;

    switch (method) {
      case 'initialize':
        result = {
          protocolVersion: '2024-11-05',
          capabilities: { tools: {}, resources: {} },
          serverInfo: {
            name: 'Book Reviews API',
            version: '1.0.0',
            description: 'Book reviews and ratings'
          }
        };
        break;

      case 'tools/list':
        result = {
          tools: [
            {
              name: 'get_books',
              description: 'Get all books with optional filters',
              inputSchema: {
                type: 'object',
                properties: {
                  category: { type: 'string', description: 'Filter by category' },
                  rating: { type: 'number', description: 'Filter by minimum rating' }
                }
              }
            },
            {
              name: 'get_book_by_id',
              description: 'Get a specific book by ID',
              inputSchema: {
                type: 'object',
                properties: {
                  id: { type: 'string', description: 'Book ID' }
                },
                required: ['id']
              }
            },
            {
              name: 'search_books',
              description: 'Search books by title or author',
              inputSchema: {
                type: 'object',
                properties: {
                  query: { type: 'string' }
                },
                required: ['query']
              }
            },
            {
              name: 'get_categories',
              description: 'Get all book categories',
              inputSchema: {
                type: 'object',
                properties: {}
              }
            }
          ]
        };
        break;

      case 'tools/call':
        const toolName = params?.name;
        const args = params?.arguments;

        switch (toolName) {
          case 'get_books':
            result = await getBooks(args);
            break;
          case 'get_book_by_id':
            result = await getBookById(args?.id);
            break;
          case 'search_books':
            result = await searchBooks(args?.query);
            break;
          case 'get_categories':
            result = ['fiction', 'non-fiction', 'tech', 'self-help', 'business', 'science'];
            break;
          default:
            throw new Error(`Unknown tool: ${toolName}`);
        }
        break;

      default:
        throw new Error(`Unknown method: ${method}`);
    }

    return NextResponse.json({
      jsonrpc: '2.0',
      id: body.id,
      result
    });

  } catch (error) {
    return NextResponse.json({
      jsonrpc: '2.0',
      id: body?.id || 1,
      error: {
        code: -32000,
        message: error instanceof Error ? error.message : 'Unknown error'
      }
    }, { status: 500 });
  }
}
